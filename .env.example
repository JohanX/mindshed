# Database (any Postgres provider — Supabase recommended)
DATABASE_URL="postgresql://mindshed:mindshed@localhost:5432/mindshed"

# Image Storage — choose a provider
IMAGE_PROVIDER="s3"  # "cloudinary" or "s3"

# Cloudinary (when IMAGE_PROVIDER=cloudinary)
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# S3-compatible (when IMAGE_PROVIDER=s3) — works with Cloudflare R2, Backblaze B2, MinIO
R2_ENDPOINT="http://localhost:9000"
R2_ACCESS_KEY_ID="mindshed"
R2_SECRET_ACCESS_KEY="mindshed123"
R2_BUCKET_NAME="mindshed-images"
R2_PUBLIC_URL=""  # optional, for production public URLs (e.g., https://pub-xxx.r2.dev)

# Auth — shared secret token for instance protection
# Set to a random string for production. Leave empty/unset for local dev (no auth).
APP_SECRET="change-me-to-a-random-string"
