// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Hobby {
  id        String   @id @default(uuid())
  name      String
  color     String
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]
  ideas    Idea[]

  @@map("hobby")
}

model Project {
  id             String   @id @default(uuid())
  name           String
  description    String?
  hobbyId        String   @map("hobby_id")
  isArchived     Boolean  @default(false) @map("is_archived")
  isCompleted    Boolean  @default(false) @map("is_completed")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  hobby Hobby  @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  steps Step[]

  @@map("project")
}

enum StepState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

model Step {
  id            String     @id @default(uuid())
  name          String
  projectId     String     @map("project_id")
  state         StepState  @default(NOT_STARTED)
  previousState StepState? @map("previous_state")
  sortOrder     Int        @default(0) @map("sort_order")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  notes    StepNote[]
  blockers Blocker[]
  images   StepImage[]

  @@map("step")
}

model StepNote {
  id        String   @id @default(uuid())
  stepId    String   @map("step_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  step Step @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("step_note")
}

model Blocker {
  id          String   @id @default(uuid())
  stepId      String   @map("step_id")
  description String
  isResolved  Boolean  @default(false) @map("is_resolved")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  step Step @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("blocker")
}

model Idea {
  id            String   @id @default(uuid())
  hobbyId       String   @map("hobby_id")
  title         String
  description   String?
  referenceLink String?  @map("reference_link")
  isPromoted    Boolean  @default(false) @map("is_promoted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)

  @@map("idea")
}

enum StepImageType {
  UPLOAD
  LINK
}

model StepImage {
  id               String        @id @default(uuid())
  stepId           String        @map("step_id")
  storageKey       String?       @map("storage_key")
  originalFilename String?       @map("original_filename")
  contentType      String?       @map("content_type")
  sizeBytes        Int?          @map("size_bytes")
  type             StepImageType @default(UPLOAD)
  url              String?
  createdAt        DateTime      @default(now()) @map("created_at")

  step Step @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("step_image")
}
