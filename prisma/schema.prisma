// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Hobby {
  id        String   @id @default(uuid())
  name      String
  color     String
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]
  ideas    Idea[]

  @@map("hobby")
}

model Project {
  id             String   @id @default(uuid())
  name           String
  description    String?
  hobbyId        String   @map("hobby_id")
  isArchived     Boolean  @default(false) @map("is_archived")
  isCompleted    Boolean  @default(false) @map("is_completed")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Gallery fields
  journeyGalleryEnabled Boolean  @default(false) @map("journey_gallery_enabled")
  resultGalleryEnabled  Boolean  @default(false) @map("result_gallery_enabled")
  gallerySlug           String?  @unique @map("gallery_slug")
  resultStepId          String?  @unique @map("result_step_id")

  hobby      Hobby     @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  steps      Step[]
  resultStep Step?     @relation("ResultStep", fields: [resultStepId], references: [id], onDelete: SetNull)
  bomItems   BomItem[]

  @@map("project")
}

enum StepState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

model Step {
  id            String     @id @default(uuid())
  name          String
  projectId     String     @map("project_id")
  state         StepState  @default(NOT_STARTED)
  previousState StepState? @map("previous_state")
  sortOrder     Int        @default(0) @map("sort_order")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  excludeFromGallery Boolean @default(false) @map("exclude_from_gallery")

  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resultForProject Project?    @relation("ResultStep")
  notes            StepNote[]
  blockers         Blocker[]
  images           StepImage[]

  @@map("step")
}

model StepNote {
  id        String   @id @default(uuid())
  stepId    String   @map("step_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  step Step @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("step_note")
}

model Blocker {
  id              String         @id @default(uuid())
  stepId          String         @map("step_id")
  description     String
  isResolved      Boolean        @default(false) @map("is_resolved")
  inventoryItemId String?        @map("inventory_item_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  step          Step           @relation(fields: [stepId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@map("blocker")
}

model Idea {
  id            String   @id @default(uuid())
  hobbyId       String   @map("hobby_id")
  title         String
  description   String?
  referenceLink String?  @map("reference_link")
  isPromoted    Boolean  @default(false) @map("is_promoted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)

  @@map("idea")
}

enum InventoryItemType {
  MATERIAL
  CONSUMABLE
  TOOL
}

model InventoryItem {
  id        String            @id @default(uuid())
  name      String
  type      InventoryItemType
  quantity  Float?
  unit      String?
  notes     String?
  isDeleted Boolean           @default(false) @map("is_deleted")
  deletedAt DateTime?         @map("deleted_at")
  lastMaintenanceDate     DateTime? @map("last_maintenance_date")
  maintenanceIntervalDays Int?      @map("maintenance_interval_days")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  blockers Blocker[]
  bomItems BomItem[]

  // Unique index UNIQUE(lower(name)) WHERE is_deleted = false enforced via raw SQL in migration
  // (Prisma cannot express partial/functional unique indexes natively).

  @@map("inventory_item")
}

enum BomConsumptionState {
  NOT_CONSUMED
  CONSUMED
  UNDONE
}

model BomItem {
  id               String              @id @default(uuid())
  projectId        String              @map("project_id")
  inventoryItemId  String?             @map("inventory_item_id")
  label            String?
  requiredQuantity Float               @map("required_quantity")
  unit             String?
  consumptionState BomConsumptionState @default(NOT_CONSUMED) @map("consumption_state")
  consumedAt       DateTime?           @map("consumed_at")
  unconsumedAt     DateTime?           @map("unconsumed_at")
  sortOrder        Int                 @default(0) @map("sort_order")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  // Partial unique index UNIQUE(project_id, inventory_item_id) WHERE inventory_item_id IS NOT NULL
  // applied via prisma/post-push.mjs.

  @@map("bom_item")
}

enum StepImageType {
  UPLOAD
  LINK
}

model StepImage {
  id               String        @id @default(uuid())
  stepId           String        @map("step_id")
  storageKey       String?       @map("storage_key")
  originalFilename String?       @map("original_filename")
  contentType      String?       @map("content_type")
  sizeBytes        Int?          @map("size_bytes")
  type             StepImageType @default(UPLOAD)
  url              String?
  createdAt        DateTime      @default(now()) @map("created_at")

  step Step @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("step_image")
}

enum ReminderTargetType {
  STEP
  PROJECT
}

model Reminder {
  id           String             @id @default(uuid())
  targetType   ReminderTargetType @map("target_type")
  targetId     String             @map("target_id")
  dueDate      DateTime           @map("due_date")
  isDismissed  Boolean            @default(false) @map("is_dismissed")
  snoozedUntil DateTime?          @map("snoozed_until")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([targetType, targetId])
  @@index([dueDate])
  @@map("reminder")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("setting")
}
